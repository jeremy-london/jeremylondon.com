---
import Container from '@components/container.astro'
import BlogExplorer from '@components/blog-explorer.astro'
import Pagetitle from '@components/page-title.astro'
import Layout from '@layouts/Layout.astro'
import { latestPosts } from '@utils/content'

export function getStaticPaths() {
  return [
    {
      params: { page: undefined },
      props: { posts: latestPosts },
    },
  ]
}

const { posts } = Astro.props as { posts: typeof latestPosts }
---

<Layout
  title="Blog"
  desc="Read Jeremy London's writing on AI systems, agent workflows, distributed systems, security, reliability, and engineering leadership.">
  <Container class="py-3 lg:py-4">
    <main class="max-w-full w-full">
      <Pagetitle>
        <Fragment slot="title">Blog Posts</Fragment>
        <Fragment slot="desc">
          Search by topic, filter by category or year, and sort through the
          archive without losing the thread.
        </Fragment>
      </Pagetitle>
      <BlogExplorer posts={posts} />
    </main>
  </Container>
</Layout>
