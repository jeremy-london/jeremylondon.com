---
import { type CollectionEntry, getCollection, render } from 'astro:content'
import Authorcard from '@components/author-card.astro'
import Container from '@components/container.astro'
import Label from '@components/ui/label.astro'
import type { Author } from '@data/authors'
import { authors } from '@data/authors'
import type { Category } from '@data/category'
import { categories } from '@data/category'
import Layout from '@layouts/Layout.astro'
import { getFormattedDate } from '@utils/all'
import { cleanMDXContent } from '@utils/content'
import { latestPosts } from '@utils/content'
import { getReadingTimeDetails } from '@utils/reading-time'
import { slugifyTag } from '@utils/tags'

interface Props {
  post: CollectionEntry<'blog'>
}

export async function getStaticPaths() {
  const blog = await getCollection('blog', ({ data }) => data.draft !== true)

  return blog.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props

const { Content } = await render(post)
const readingTimeText = getReadingTimeDetails(cleanMDXContent(post.body)).minutesRead

const author = authors.find((item) => item.slug === post.data.author) as Author
const category = categories.find(
  (item) => item.slug === post.data.category,
) as Category
const currentPostIndex = latestPosts.findIndex((item) => item.id === post.id)
const nextPost = currentPostIndex > 0 ? latestPosts[currentPostIndex - 1] : null
const previousPost =
  currentPostIndex >= 0 && currentPostIndex < latestPosts.length - 1
    ? latestPosts[currentPostIndex + 1]
    : null
const postImage =
  typeof post.data.image === 'string' ? post.data.image : post.data.image?.src
const monthParam = post.data.publishDate.toISOString().slice(0, 7)
const monthLabel = post.data.publishDate.toLocaleDateString('en-us', {
  month: 'long',
})
const dayLabel = String(post.data.publishDate.getDate())
const yearLabel = String(post.data.publishDate.getFullYear())
const currentTags = new Set(post.data.tags.map((tag: string) => slugifyTag(tag)))
const relatedPosts = latestPosts
  .filter((item) => item.id !== post.id)
  .map((item) => {
    const sharedTags =
      item.data.tags?.filter((tag: string) => currentTags.has(slugifyTag(tag)))
        .length ?? 0
    const categoryMatch = item.data.category === post.data.category ? 2 : 0

    return {
      post: item,
      score: sharedTags + categoryMatch,
    }
  })
  .filter((item) => item.score > 0)
  .sort(
    (a, b) =>
      b.score - a.score ||
      b.post.data.publishDate.valueOf() - a.post.data.publishDate.valueOf(),
  )
  .slice(0, 3)
---

<Layout
  title={post.data.title}
  desc={post.data.excerpt}
  type="article"
  publishedTime={post.data.publishDate.toISOString()}
  section={category.title}
  tags={post.data.tags}
  ogimage={postImage}
  load_pyodide={post.data.load_pyodide}
  load_mathjax={post.data.load_mathjax}>
  <div
    data-reading-progress-shell
    class="pointer-events-none fixed left-3 top-1/2 z-40 hidden -translate-y-1/2 opacity-0 transition-[opacity,transform] duration-300 ease-out motion-reduce:transition-none sm:block"
    aria-hidden="true">
    <div class="flex items-center gap-1">
      <div class="relative h-56 w-1.5 overflow-hidden rounded-full bg-gray-200/80 shadow-sm shadow-gray-950/5 dark:bg-gray-800/80">
        <div
          data-reading-progress
          class="absolute left-0 top-0 h-0 w-full rounded-full bg-blue-600 transition-[height] duration-200 ease-out dark:bg-orange-400"></div>
      </div>
      <div
        data-reading-progress-label
        class="text-[10px] font-normal tabular-nums leading-none text-gray-500 dark:text-gray-400">
        0%
      </div>
    </div>
  </div>

  <div class="relative">
    <Container>
      <div class="max-w-full w-full">
        <div>
          <a
            href={`/category/${category.slug}`}
            class="inline-flex min-h-11 items-center rounded px-1 transition hover:[&_span]:text-blue-700 dark:hover:[&_span]:text-orange-300">
            <Label theme={category.color}>{category.title}</Label>
          </a>
        </div>

        <h1
          class="mt-2 mb-3 text-3xl font-semibold tracking-tight text-brand-primary text-balance lg:leading-snug lg:text-4xl dark:text-white">
          {post.data.title}
        </h1>

        <div class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-gray-500 dark:text-gray-400">
          <time datetime={post.data.publishDate.toISOString()} class="type-meta whitespace-nowrap text-gray-500 dark:text-gray-400">
            <a
              href={`/blog?month=${monthParam}`}
              aria-label={`View posts from ${monthLabel} ${yearLabel}`}
              class="transition hover:text-blue-700 dark:hover:text-orange-300">
              {monthLabel}
            </a>
            {' '}
            <span>{dayLabel}</span>
            {' '}
            <a
              href={`/blog?year=${yearLabel}`}
              aria-label={`View posts from ${yearLabel}`}
              class="transition hover:text-blue-700 dark:hover:text-orange-300">
              {yearLabel}
            </a>
          </time>
          <span aria-hidden="true" class="type-meta text-gray-300 dark:text-gray-600">//</span>
          <span class="type-meta whitespace-nowrap text-gray-500 dark:text-gray-400">{readingTimeText}</span>
        </div>
      </div>
    </Container>

    <Container>
      <article class="w-full max-w-full" data-reading-article>
        <div
          data-reading-content
          class="prose prose-base mx-auto my-3 w-full max-w-none dark:prose-invert prose-a:text-blue-600 hover:prose-a:text-blue-800 dark:prose-a:text-orange-500 dark:hover:prose-a:text-orange-400">
          <Content />

          <div class="flex w-full flex-wrap items-center gap-3 md:w-auto">
            {
              post.data.tags.map((tag: string) => (
                <a
                  href={`/tag/${slugifyTag(tag)}`}
                  class="not-prose inline-flex min-h-9 items-center rounded border border-gray-200 px-3 text-sm text-gray-600 transition hover:border-blue-300 hover:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:border-gray-800 dark:text-gray-300 dark:hover:border-orange-700 dark:hover:text-orange-300 dark:focus-visible:ring-orange-500">
                  #{tag}
                </a>
              ))
            }
          </div>
        </div>

        <nav
          class="mt-10 border-t border-gray-200 py-4 dark:border-gray-800"
          aria-label="Post navigation">
          <div class="grid gap-4 sm:grid-cols-2">
            {
              previousPost && (
                <a
                  href={`/blog/${previousPost.id}`}
                  class="motion-rise motion-lift group block rounded-md border border-gray-200 p-4 transition hover:border-blue-300 dark:border-gray-800 dark:hover:border-orange-700"
                  style="--i: 0">
                  <span class="text-xs font-medium text-gray-500 dark:text-gray-400">
                    Previous
                  </span>
                  <span class="mt-2 block text-sm font-semibold leading-6 text-gray-950 group-hover:text-blue-700 dark:text-white dark:group-hover:text-orange-300">
                    {previousPost.data.title}
                  </span>
                </a>
              )
            }
            {
              nextPost && (
                <a
                  href={`/blog/${nextPost.id}`}
                  class="motion-rise motion-lift group block rounded-md border border-gray-200 p-4 transition hover:border-blue-300 dark:border-gray-800 dark:hover:border-orange-700 sm:text-right"
                  style="--i: 1">
                  <span class="text-xs font-medium text-gray-500 dark:text-gray-400">
                    Next
                  </span>
                  <span class="mt-2 block text-sm font-semibold leading-6 text-gray-950 group-hover:text-blue-700 dark:text-white dark:group-hover:text-orange-300">
                    {nextPost.data.title}
                  </span>
                </a>
              )
            }
          </div>
          <div class="mt-6">
            <a
              href="/blog"
              class="text-sm font-medium text-blue-700 underline decoration-blue-300 underline-offset-4 transition hover:text-blue-900 dark:text-orange-300 dark:decoration-orange-700 dark:hover:text-orange-200">
              View all posts
            </a>
          </div>
        </nav>

        {
          relatedPosts.length > 0 && (
            <section class="mt-10" aria-labelledby="related-posts-heading">
              <h2
                id="related-posts-heading"
                class="text-xl font-semibold text-gray-950 dark:text-white">
                Related posts
              </h2>
              <div class="mt-4 divide-y divide-gray-200 dark:divide-gray-800">
                {relatedPosts.map(({ post: relatedPost }, index) => (
                  <a
                    href={`/blog/${relatedPost.id}`}
                    class="motion-rise motion-lift group flex flex-col gap-1 py-4 text-sm transition sm:flex-row sm:items-baseline sm:justify-between sm:gap-6"
                    style={`--i: ${index}`}>
                    <span class="font-medium text-gray-950 group-hover:text-blue-700 dark:text-white dark:group-hover:text-orange-300">
                      {relatedPost.data.title}
                    </span>
                    <span class="shrink-0 text-gray-500 dark:text-gray-400">
                      {getFormattedDate(relatedPost.data.publishDate)}
                    </span>
                  </a>
                ))}
              </div>
            </section>
          )
        }

        {author && <Authorcard author={author} />}
      </article>
    </Container>
  </div>
</Layout>

<script is:inline>
  const progress = document.querySelector("[data-reading-progress]");
  const progressShell = document.querySelector("[data-reading-progress-shell]");
  const progressLabel = document.querySelector("[data-reading-progress-label]");
  const content = document.querySelector("[data-reading-content]");

  if (progress && content && progressShell && progressLabel) {
    const updateProgress = () => {
      const contentRect = content.getBoundingClientRect();
      const contentTop = window.scrollY + contentRect.top;
      const contentBottom = contentTop + contentRect.height;
      const scrollStart = contentTop - window.innerHeight * 0.18;
      const scrollEnd = Math.max(contentBottom - window.innerHeight, scrollStart + 1);
      const ratio = (window.scrollY - scrollStart) / (scrollEnd - scrollStart);
      const value = Math.max(0, Math.min(100, ratio * 100));
      progress.style.height = `${value}%`;
      progressLabel.textContent = `${Math.round(value)}%`;

      const fadeInStart = contentTop - 72;
      const fadeInDistance = 120;
      const fadeOutStart = contentBottom - window.innerHeight * 0.2;
      const fadeOutDistance = 120;
      const fadeIn = Math.max(
        0,
        Math.min(1, (window.scrollY - fadeInStart) / fadeInDistance),
      );
      const fadeOut = Math.max(
        0,
        Math.min(1, (fadeOutStart - window.scrollY) / fadeOutDistance),
      );
      const completionFadeStart = scrollEnd + 500;
      const completionFadeDistance = 220;
      const completionFade = Math.max(
        0,
        Math.min(
          1,
          1 - (window.scrollY - completionFadeStart) / completionFadeDistance,
        ),
      );
      const visibility = Math.min(fadeIn, fadeOut, completionFade);

      progressShell.style.opacity = `${visibility}`;
      progressShell.style.transform = `translateY(${(1 - visibility) * -0.35}rem) translateX(${(1 - visibility) * -0.15}rem)`;
    };

    updateProgress();
    window.addEventListener("scroll", updateProgress, { passive: true });
    window.addEventListener("resize", updateProgress);
  }
</script>
