---
import Container from '@components/container.astro'
import Link from '@components/ui/link.astro'
import Layout from '@layouts/Layout.astro'
import { Image } from 'astro:assets'
import NotFoundImg from '@assets/404.webp'
---

<Layout title="404 - Page Not Found">
  <Container>
    <header class="max-w-full w-full">
      <div class="flex flex-col items-center justify-center gap-10 h-[75vh]">
        <div class="flex w-full max-w-2xl flex-col items-center text-center">
          <h1 class="text-4xl font-bold leading-tight text-brand-primary sm:text-5xl dark:text-white">
            Page not found
          </h1>
          <p class="mt-4 max-w-2xl text-lg leading-8 text-gray-600 dark:text-gray-300">
            That URL does not map to anything here. The useful paths are still
            close by: visit my blog or go back to the homepage.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <Link href="/blog">Read my blog</Link>
            <Link href="/" style="outline">Go home</Link>
          </div>
        </div>

        <figure class="cool-profile mx-auto w-full max-w-80" aria-label="404 illustration">
          <span class="cool-profile__orbit cool-profile__orbit--back" aria-hidden="true"></span>
          <span class="cool-profile__orbit cool-profile__orbit--front" aria-hidden="true"></span>
          <Image
            src={NotFoundImg}
            alt="Abstract 404 illustration"
            format="avif"
            class="cool-profile__image border border-gray-200 dark:border-gray-800"
          />
        </figure>
      </div>
    </header>
  </Container>
</Layout>
