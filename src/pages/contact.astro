---
import ContactForm from '@components/contact-form.astro'
import Container from '@components/container.astro'
import PageTitle from '@components/page-title.astro'
import Layout from '@layouts/Layout.astro'
import { Icon } from 'astro-icon/components'

const usefulContext = [
  'What you want to discuss',
  'The constraints or links that matter',
  'How urgent it is and the best way to reply',
]
---

<Layout
  title="Contact Jeremy London about engineering collaboration"
  desc="Contact Jeremy London about engineering leadership, AI systems, security, reliability, consulting, writing, or technical collaboration.">
  <Container>
    <PageTitle>
      <Fragment slot="title">Contact me</Fragment>
      <Fragment slot="desc">
        Contact me about engineering work, writing, speaking, or
        collaboration.
      </Fragment>
    </PageTitle>

    <div class="mt-5 grid max-w-full w-full gap-10 md:grid-cols-[0.82fr_1.18fr] lg:gap-16">
      <div class="md:pt-4">
        <div class="py-4">
          <h2 class="text-sm font-semibold text-gray-950 dark:text-white">
            What helps
          </h2>
          <ul class="mt-4 divide-y divide-gray-200 dark:divide-gray-800">
            {
              usefulContext.map((item) => (
                <li class="flex gap-3 py-3 text-sm leading-6 text-gray-600 first:pt-0 last:pb-0 dark:text-gray-300">
                  <Icon
                    class="mt-1 h-4 w-4 shrink-0 text-blue-600 dark:text-orange-400"
                    name="heroicons-outline:check"
                  />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="mt-10">
          <h2 class="text-sm font-semibold text-gray-950 dark:text-white">
            Other ways to reach me
          </h2>
        </div>
        <div class="mt-3 space-y-2">
          <div
            class="group flex min-h-11 items-center space-x-2 text-gray-600 dark:text-gray-400">
            <Icon
              class="w-4 h-4 text-gray-400 group-hover:text-blue-500 dark:group-hover:text-orange-500"
              name="uil:envelope"
            />
            <a
              class="inline-flex min-h-11 items-center hover:underline group-hover:text-blue-500 dark:group-hover:text-orange-500"
              href="mailto:jeremy.c.london@gmail.com">
              jeremy.c.london@gmail.com
            </a>
          </div>

          <div
            class="group flex min-h-11 items-center space-x-2 text-gray-600 dark:text-gray-400">
            <Icon
              class="w-4 h-4 text-gray-400 group-hover:text-blue-500 dark:group-hover:text-orange-500"
              name="uil:github"
            />
            <a
              class="inline-flex min-h-11 items-center hover:underline group-hover:text-blue-500 dark:group-hover:text-orange-500"
              href="https://github.com/jeremy-london"
              target="_blank"
              rel="noopener noreferrer">
              jeremy-london
            </a>
          </div>

          <div
            class="group flex min-h-11 items-center space-x-2 text-gray-600 dark:text-gray-400">
            <Icon
              class="w-4 h-4 text-gray-400 group-hover:text-blue-500 dark:group-hover:text-orange-500"
              name="uil:linkedin"
            />
            <a
              class="inline-flex min-h-11 items-center hover:underline group-hover:text-blue-500 dark:group-hover:text-orange-500"
              href="https://www.linkedin.com/in/jeremyclondon/"
              target="_blank"
              rel="noopener noreferrer">
              Jeremy London
            </a>
          </div>
        </div>
      </div>
      <div class="py-4 sm:py-5">
        <div class="mb-5">
          <h2 class="text-xl font-semibold text-brand-primary dark:text-white">
            Send a note
          </h2>
          <p class="mt-2 max-w-full text-sm leading-6 text-gray-600 dark:text-gray-300">
            Share enough context for me to route the conversation and reply
            usefully.
          </p>
        </div>
        <ContactForm />
      </div>
    </div>
  </Container>
</Layout>
