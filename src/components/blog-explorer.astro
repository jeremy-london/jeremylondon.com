              <div class="mt-2 flex gap-2">
                <button type="button" data-combobox-all data-value="" data-option-label="All tags" class="motion-lift inline-flex min-h-10 flex-1 items-center justify-center rounded border border-gray-200 px-3 text-sm font-medium text-gray-700 hover:bg-gray-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:border-gray-800 dark:text-gray-200 dark:hover:bg-gray-900 dark:focus-visible:ring-orange-500">
