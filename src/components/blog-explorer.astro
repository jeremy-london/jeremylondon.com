---
import PostList from '@components/post-list.astro'
import { categories } from '@data/category'
import { cleanMDXContent } from '@utils/content'
import { slugifyTag } from '@utils/tags'
import { getReadingTimeDetails } from '@utils/reading-time'

const { posts, class: className } = Astro.props

const categoryCounts = new Map<string, number>()
const tagCounts = new Map<string, { label: string; count: number }>()
const years = new Set<string>()

posts.forEach((post: any) => {
  categoryCounts.set(
    post.data.category,
    (categoryCounts.get(post.data.category) ?? 0) + 1,
  )
  years.add(String(post.data.publishDate.getFullYear()))
  post.data.tags?.forEach((tag: string) => {
    const slug = slugifyTag(tag)
    const entry = tagCounts.get(slug) ?? { label: tag, count: 0 }
    entry.count += 1
    tagCounts.set(slug, entry)
  })
})

const activeCategories = categories
  .map((category) => ({
    ...category,
    count: categoryCounts.get(category.slug) ?? 0,
  }))
  .filter((category) => category.count > 0)

const sortedYears = [...years].sort((a, b) => Number(b) - Number(a))
const activeTags = [...tagCounts.entries()]
  .map(([slug, entry]) => ({ slug, ...entry }))
  .sort((a, b) => a.label.localeCompare(b.label))

const sortOptions = [
  ['newest', 'Newest first'],
  ['oldest', 'Oldest first'],
  ['short', 'Shortest first'],
  ['long', 'Longest first'],
]

const categoryTitle = (slug: string) =>
  categories.find((category) => category.slug === slug)?.title ?? slug

const readingTimes = new Map<
  string,
  { minutesRead: string; readingTimeMinutes: number }
>(
  posts.map((post: any) => [
    post.id,
    getReadingTimeDetails(cleanMDXContent(post.body)),
  ]),
)
---

