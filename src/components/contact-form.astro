---
import Button from '@components/ui/button.astro'
import Field from '@components/ui/field.astro'

const ACCESS_KEY = '34f91303-a354-4767-a3b8-617380503ddb'
const webmcpFormAttrs: Record<string, string> = {
  'data-webmcp-tool': 'contact_jeremy_london',
  'data-webmcp-description':
    'Send Jeremy London a message about engineering work, writing, speaking, collaboration, or a question about the site.',
}
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  id="form"
  data-contact-form
  class="needs-validation"
  {...webmcpFormAttrs}>
  <input type="hidden" name="access_key" value={ACCESS_KEY} />

  <input
    type="hidden"
    name="subject"
    value="New Submission from jeremylondon.com web3form"
  />
  <input type="hidden" name="from_name" value="jeremylondon | contact" />
  <input type="checkbox" class="sr-only" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <Field
    id="contact_name"
    label="Full name"
    name="name"
    data-webmcp-description="The sender's full name."
    placeholder="Jane Smith"
    required
    autocomplete="name"
    minlength="2"
    maxlength="120"
    enterkeyhint="next"
    emptyMessage="Please provide your full name."
  />
  <Field
    id="email_address"
    label="Email address"
    name="email"
    type="email"
    data-webmcp-description="The sender's email address."
    placeholder="name@example.com"
    required
    autocomplete="email"
    inputmode="email"
    maxlength="254"
    enterkeyhint="next"
    emptyMessage="Please provide your email address."
    invalidMessage="Email addresses need an @ symbol. Try name@example.com."
  />
  <Field
    id="contact_message"
    label="Message"
    name="message"
    multiline
    data-webmcp-description="What you want to discuss, ask, or build together."
    required
    placeholder="What should I know before replying?"
    minlength="10"
    maxlength="4000"
    enterkeyhint="send"
    emptyMessage="Please enter your message."
    invalidMessage="Messages need at least 10 characters."
  />
  <div class="mt-5 space-y-3">
    <Button type="submit" size="lg" block>Send message</Button>
    <p class="text-sm leading-6 text-gray-500 dark:text-gray-400">
      Prefer email? Use the address on this page.
    </p>
  </div>
  <div id="result" class="mt-4 text-sm leading-6" role="status" aria-live="polite"></div>
</form>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .field-error-visible {
    display: block;
  }

</style>

<script is:inline>
  const form = document.getElementById("form");
  const result = document.getElementById("result");
  const submitButton = form.querySelector('button[type="submit"]');
  const submitLabel = submitButton ? submitButton.textContent : "";
  const controls = Array.from(form.querySelectorAll("input:not([type='hidden']):not([name='botcheck']), textarea"));

  function setResult(message, tone = "neutral") {
    result.textContent = message;
    result.className = "mt-4 text-sm leading-6";

    if (tone === "success") {
      result.classList.add("text-green-600", "dark:text-green-400");
    }

    if (tone === "error") {
      result.classList.add("text-red-600", "dark:text-red-400");
    }
  }

  function validateControl(control) {
    const field = control.closest("[data-field-shell]");
    const emptyFeedback = field.querySelector(".empty-feedback");
    const invalidFeedback = field.querySelector(".invalid-feedback");
    const isEmpty = control.validity.valueMissing;
    const isInvalid = !control.validity.valid;
    const showError = control.matches(":user-invalid") || control.getAttribute("aria-invalid") === "true";

    const showEmpty = showError && isEmpty;
    const showInvalid = showError && isInvalid && !isEmpty;

    emptyFeedback.classList.toggle("field-error-visible", showEmpty);
    emptyFeedback.hidden = !showEmpty;
    if (invalidFeedback) {
      invalidFeedback.classList.toggle("field-error-visible", showInvalid);
      invalidFeedback.hidden = !showInvalid;
    }

    control.setAttribute("aria-invalid", showError && isInvalid ? "true" : "false");
    if (showEmpty) {
      control.setAttribute("aria-errormessage", emptyFeedback.id);
    } else if (showInvalid && invalidFeedback) {
      control.setAttribute("aria-errormessage", invalidFeedback.id);
    } else {
      control.removeAttribute("aria-errormessage");
    }

    return !isInvalid;
  }

  function clearValidationState() {
    controls.forEach((control) => {
      control.setCustomValidity("");
      control.setAttribute("aria-invalid", "false");
      control.removeAttribute("aria-errormessage");
    });
    form.querySelectorAll(".field-error-visible").forEach((node) => {
      node.classList.remove("field-error-visible");
    });
    form.querySelectorAll(".empty-feedback, .invalid-feedback").forEach((node) => {
      node.hidden = true;
    });
  }

  controls.forEach((control) => {
    control.setAttribute("aria-invalid", "false");
    control.removeAttribute("aria-errormessage");

    control.addEventListener("input", () => {
      validateControl(control);
      if (form.checkValidity()) {
        setResult("");
      }
    });

    control.addEventListener("blur", () => {
      validateControl(control);
    });
  });

  form.addEventListener("invalid", (event) => {
    if (!controls.includes(event.target)) return;
    event.target.setAttribute("aria-invalid", "true");
    validateControl(event.target);
    if (!result.textContent) {
      setResult("Check the highlighted fields and try again.", "error");
    }
  }, true);

  form.addEventListener("submit", function (e) {
    e.preventDefault();

    controls.forEach((control) => {
      control.setAttribute("aria-invalid", control.checkValidity() ? "false" : "true");
      validateControl(control);
    });

    if (!form.checkValidity()) {
      const firstInvalid = form.querySelector('[aria-invalid="true"]');
      setResult("Check the highlighted fields and try again.", "error");
      firstInvalid?.focus();
      return;
    }

    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    setResult("Sending message...");
    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = "Sending...";
    }

    fetch("https://api.web3forms.com/submit", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: json,
    })
      .then(async (response) => {
        let json = {};
        try {
          json = await response.json();
        } catch {
          json = {};
        }

        if (response.status == 200) {
          setResult(json.message || "Message sent. I'll reply as soon as I can.", "success");
          form.reset();
          clearValidationState();
          setTimeout(() => {
            setResult("");
          }, 5000);
        } else {
          setResult(
            json.message || "The message did not send. Please email me directly instead.",
            "error",
          );
        }
      })
      .catch(() => {
        setResult(
          "We could not reach the form service. Please email me directly instead.",
          "error",
        );
      })
      .finally(() => {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = submitLabel;
        }
      });
  });
</script>
