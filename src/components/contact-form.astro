---
import Button from '@components/ui/button.astro'
import Field from '@components/ui/field.astro'

const ACCESS_KEY = '34f91303-a354-4767-a3b8-617380503ddb'
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  id="form"
  class="needs-validation"
  novalidate>
  <input type="hidden" name="access_key" value={ACCESS_KEY} />

  <input
    type="hidden"
    name="subject"
    value="New Submission from jeremylondon.com web3form"
  />
  <input type="hidden" name="from_name" value="jeremylondon | contact" />
  <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
  <Field
    id="contact_name"
    label="Full name"
    name="name"
    placeholder="Jane Smith"
    required
    emptyMessage="Please provide your full name."
  />
  <Field
    id="email_address"
    label="Email address"
    name="email"
    type="email"
    placeholder="name@example.com"
    required
    emptyMessage="Please provide your email address."
    invalidMessage="Email addresses need an @ symbol. Try name@example.com."
  />
  <Field
    id="contact_message"
    label="Message"
    name="message"
    multiline
    required
    placeholder="What should I know before replying?"
    emptyMessage="Please enter your message."
  />
  <div class="mt-5 space-y-3">
    <Button type="submit" size="lg" block>Send message</Button>
    <p class="text-sm leading-6 text-gray-500 dark:text-gray-400">
      Prefer email? Use the address on this page.
    </p>
  </div>
  <div id="result" class="mt-4 text-sm leading-6" role="status" aria-live="polite"></div>
</form>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .field-error-visible {
    display: block;
  }

  .is-invalid {
    border-color: #ef4444;
  }
</style>

<script is:inline>
  const form = document.getElementById("form");
  const result = document.getElementById("result");
  const submitButton = form.querySelector('button[type="submit"]');
  const submitLabel = submitButton ? submitButton.textContent : "";
  const fields = Array.from(form.querySelectorAll("[data-field-shell]"));
  const controls = fields
    .map((field) => field.querySelector("input, textarea"))
    .filter(Boolean);
  let hasSubmitted = false;

  function setResult(message, tone = "neutral") {
    result.textContent = message;
    result.className = "mt-4 text-sm leading-6";

    if (tone === "success") {
      result.classList.add("text-green-600", "dark:text-green-400");
    }

    if (tone === "error") {
      result.classList.add("text-red-600", "dark:text-red-400");
    }
  }

  function syncControlValidity(control) {
    const value = control.value.trim();
    const isEmpty = control.required && value.length === 0;

    control.setCustomValidity(isEmpty ? " " : "");

    return { isEmpty, isInvalid: !control.validity.valid };
  }

  function validateControl(control, shouldShowErrors) {
    const field = control.closest("[data-field-shell]");
    const emptyFeedback = field.querySelector(".empty-feedback");
    const invalidFeedback = field.querySelector(".invalid-feedback");
    const { isEmpty, isInvalid } = syncControlValidity(control);

    const showEmpty = shouldShowErrors && isEmpty;
    const showInvalid = shouldShowErrors && isInvalid && !isEmpty;

    emptyFeedback.classList.toggle("field-error-visible", showEmpty);
    emptyFeedback.hidden = !showEmpty;
    if (invalidFeedback) {
      invalidFeedback.classList.toggle("field-error-visible", showInvalid);
      invalidFeedback.hidden = !showInvalid;
    }

    control.classList.toggle("is-invalid", shouldShowErrors && isInvalid);
    control.setAttribute("aria-invalid", shouldShowErrors && isInvalid ? "true" : "false");

    return !isInvalid;
  }

  function isFormValid() {
    return controls
      .map((control) => !syncControlValidity(control).isInvalid)
      .every(Boolean);
  }

  function validateForm(shouldShowErrors) {
    return controls
      .map((control) => validateControl(control, shouldShowErrors))
      .every(Boolean);
  }

  function clearValidationState() {
    hasSubmitted = false;
    controls.forEach((control) => {
      control.setCustomValidity("");
      control.classList.remove("is-invalid");
      control.setAttribute("aria-invalid", "false");
    });
    form.querySelectorAll(".field-error-visible").forEach((node) => {
      node.classList.remove("field-error-visible");
    });
    form.querySelectorAll(".empty-feedback, .invalid-feedback").forEach((node) => {
      node.hidden = true;
    });
  }

  controls.forEach((control) => {
    control.setAttribute("aria-invalid", "false");
    validateControl(control, false);

    control.addEventListener("input", () => {
      if (!hasSubmitted) return;
      validateControl(control, true);
      if (isFormValid()) {
        setResult("");
      }
    });

    control.addEventListener("blur", () => {
      if (!hasSubmitted) return;
      validateControl(control, true);
    });
  });

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    hasSubmitted = true;

    if (!validateForm(true)) {
      const firstInvalid = form.querySelector('[aria-invalid="true"]');
      setResult("Check the highlighted fields and try again.", "error");
      firstInvalid?.focus();
      return;
    }

    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    setResult("Sending message...");
    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = "Sending...";
    }

    fetch("https://api.web3forms.com/submit", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: json,
    })
      .then(async (response) => {
        let json = {};
        try {
          json = await response.json();
        } catch {
          json = {};
        }

        if (response.status == 200) {
          setResult(json.message || "Message sent. I'll reply as soon as I can.", "success");
          form.reset();
          clearValidationState();
          setTimeout(() => {
            setResult("");
          }, 5000);
        } else {
          setResult(
            json.message || "The message did not send. Please email me directly instead.",
            "error",
          );
        }
      })
      .catch(() => {
        setResult(
          "We could not reach the form service. Please email me directly instead.",
          "error",
        );
      })
      .finally(() => {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = submitLabel;
        }
      });
  });
</script>
