---
import Label from '@components/ui/label.astro'
import type { Category } from '@data/category'
import { categories } from '@data/category'
import { cleanMDXContent } from '@utils/content'
import { getReadingTimeDetails } from '@utils/reading-time'
import { slugifyTag } from '@utils/tags'
import { Image } from 'astro:assets'

const {
  post,
  aspect = 'square',
  preloadImage = false,
  minutesRead,
  readingTimeMinutes,
} = Astro.props
const category = categories.find(
  (item) => item.slug === post.data.category,
) as Category
const postHref = `/blog/${post.id}`
const readingTime = minutesRead
  ? { minutesRead, readingTimeMinutes: readingTimeMinutes ?? 1 }
  : getReadingTimeDetails(cleanMDXContent(post.body))
const readingTimeText = readingTime.minutesRead
const readingMinutes =
  readingTimeMinutes ?? readingTime.readingTimeMinutes
const publishDate = post.data.publishDate
const monthLabel = publishDate.toLocaleDateString('en-us', {
  month: 'long',
})
const dayLabel = String(publishDate.getDate())
const monthParam = publishDate.toISOString().slice(0, 7)
const yearLabel = String(publishDate.getFullYear())
---

<article class="motion-lift group relative">
  {
    post.data.image && (
      <a
        href={postHref}
        aria-label={`Read ${post.data.title}`}
        class:list={[
          "mb-6 block overflow-hidden rounded-md border border-gray-200 bg-gray-100 transition duration-300 ease-out group-hover:border-blue-200 dark:border-gray-800 dark:bg-gray-900 dark:group-hover:border-orange-800/70",
          aspect === "landscape" ? "aspect-video" : "aspect-4/3",
        ]}>
        <Image
          src={post.data.image}
          sizes="(max-width: 640px) 90vw, 480px"
          alt={post.data.title}
          format="avif"
          loading={preloadImage ? "eager" : "lazy"}
          decoding="async"
          width={600}
          height={600}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        />
      </a>
    )
  }

  <a
    href={`/category/${category.slug}`}
    class="inline-flex min-h-11 items-center rounded px-1 transition hover:[&_span]:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:hover:[&_span]:text-orange-300 dark:focus-visible:ring-orange-500">
    <Label theme={category.color}>{category.title}</Label>
  </a>
  <h2
    class="mt-1 text-lg font-semibold tracking-normal text-brand-primary dark:text-white">
    <a
      href={postHref}
      class="group inline-flex min-h-11 items-center text-gray-950 dark:text-white">
      <span class="relative inline-block pb-1 transition-transform duration-300 ease-out group-hover:-translate-y-0.5">
        {post.data.title}
        <span
          aria-hidden="true"
          class="absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-40 bg-current opacity-50 transition-all duration-300 ease-out group-hover:scale-x-100 group-hover:opacity-100"></span>
      </span>
    </a>
  </h2>

  {
    post.data.excerpt && (
      <p class="mt-1 line-clamp-2 text-sm leading-6 text-gray-600 dark:text-gray-300">
        <a href={postHref} class="inline-flex min-h-11 items-center">
          {post.data.excerpt}
        </a>
      </p>
    )
  }

  <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-gray-500 dark:text-gray-400">
    <span class="type-meta whitespace-nowrap text-gray-500 dark:text-gray-400">
      <time datetime={publishDate.toISOString()}>
        <a
          href={`/blog?month=${monthParam}`}
          aria-label={`View posts from ${monthLabel} ${yearLabel}`}
          class="transition hover:text-blue-700 dark:hover:text-orange-300">
          {monthLabel}
        </a>
        {' '}
        <span>{dayLabel}</span>
        {' '}
        <a
          href={`/blog?year=${yearLabel}`}
          aria-label={`View posts from ${yearLabel}`}
          class="transition hover:text-blue-700 dark:hover:text-orange-300">
          {yearLabel}
        </a>
      </time>
    </span>
    <span aria-hidden="true" class="type-meta text-gray-300 dark:text-gray-600">//</span>
    <span class="type-meta whitespace-nowrap text-gray-500 dark:text-gray-400" data-reading-minutes={readingMinutes}>{readingTimeText}</span>
  </div>

  {
    post.data.tags?.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {post.data.tags.slice(0, 4).map((tag: string) => (
          <a
            href={`/tag/${slugifyTag(tag)}`}
            class="inline-flex min-h-8 items-center rounded border border-gray-200 px-2.5 text-xs text-gray-600 transition hover:bg-gray-100 hover:text-gray-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:border-gray-800 dark:text-gray-300 dark:hover:bg-gray-900 dark:hover:text-white dark:focus-visible:ring-orange-500">
            #{tag}
          </a>
        ))}
      </div>
    )
  }

  <div class="mt-4 flex items-center justify-between gap-3">
    <a
      href={postHref}
      class="inline-flex min-h-10 items-center rounded-md border border-transparent px-0 text-sm font-medium text-gray-500 opacity-0 transition duration-300 ease-out group-hover:translate-x-0 group-hover:opacity-100 group-focus-within:opacity-100 dark:text-gray-400">
      Open post
      <span aria-hidden="true" class="ml-2 transition-transform duration-300 ease-out group-hover:translate-x-1">
        →
      </span>
    </a>
  </div>
</article>
