---
import PostList from '@components/post-list.astro'
import Link from '@components/ui/link.astro'
import { latestPosts } from '@utils/content'

const { class: className, category } = Astro.props

const postsList = latestPosts
  ?.filter((post: any) => post?.data?.category === category?.slug)
  ?.slice(0, 3)
---

{
  postsList?.length ? (
    <>
      <section
        class:list={["mt-10 flex flex-wrap items-center justify-between gap-3 border-t border-gray-200 pt-8 first:border-t-0 first:pt-0 dark:border-gray-800", className]}>
        <h2 class="min-w-0 text-xl font-semibold text-gray-950 dark:text-white">
          {category?.title}
        </h2>
        <Link
          href={`/category/${category?.slug}`}
          style="underline"
          size="unset">
          See All
        </Link>
      </section>
      <div class="mt-4 grid gap-x-10 gap-y-6 md:grid-cols-3">
        {postsList?.map((post) => (
          <PostList post={post} aspect="square" />
        ))}
      </div>
    </>
  ) : null
}
