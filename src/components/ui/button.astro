---
interface Props {
  size?: 'md' | 'lg'
  block?: boolean
  style?: 'outline' | 'primary' | 'inverted'
  class?: string
  [x: string]: any
}

const {
  size = 'md',
  style = 'primary',
  block,
  class: className,
  ...rest
} = Astro.props

const sizes = {
  md: 'min-h-11 px-5 py-2.5',
  lg: 'min-h-11 px-6 py-3',
}

const styles = {
  outline: 'border-2 border-black hover:bg-black text-black hover:text-white',
  primary:
    'bg-black text-white hover:bg-gray-900  border-2 border-transparent dark:bg-white dark:text-black dark:hover:bg-gray-300',
  inverted:
    'bg-white text-black hover:bg-gray-100 border-2 border-transparent',
}
---

<button
  {...rest}
  class:list={[
    "motion-lift motion-glow inline-flex items-center justify-center rounded text-center transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 dark:focus-visible:ring-orange-500 dark:focus-visible:ring-offset-gray-950",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</button>
